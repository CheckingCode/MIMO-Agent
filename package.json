{
  "name": "mimo-agent",
  "displayName": "MiMo",
  "description": "AI coding agent powered by Xiaomi MiMo LLM",
  "version": "1.4.0",
  "publisher": "mimo-agent",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "agent",
    "mimo",
    "xiaomi",
    "coding",
    "chat",
    "code review",
    "refactor",
    "中文",
    "人工智能"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/mimo-agent-vscode"
  },
  "bugs": {
    "url": "https://github.com/your-username/mimo-agent-vscode/issues"
  },
  "homepage": "https://github.com/your-username/mimo-agent-vscode#readme",
  "license": "MIT",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mimo-agent.chat",
        "title": "MiMo: Open Chat",
        "icon": "assets/mimo-agent-icon.svg"
      },
      {
        "command": "mimo-agent.clear",
        "title": "MiMo: Clear Conversation",
        "icon": "assets/mimo-agent-icon.svg"
      },
      {
        "command": "mimo-agent.newChat",
        "title": "MiMo: New Chat Window",
        "icon": "assets/mimo-agent-icon.svg"
      },
      {
        "command": "mimo-agent.settings",
        "title": "MiMo: Settings",
        "icon": "assets/mimo-agent-icon.svg"
      },
      {
        "command": "mimo-agent.explain",
        "title": "MiMo: Explain Code"
      },
      {
        "command": "mimo-agent.review",
        "title": "MiMo: Review Code"
      },
      {
        "command": "mimo-agent.refactor",
        "title": "MiMo: Refactor Code"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mimo-agent.chat",
          "when": "editorIsOpen",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mimo-agent.explain",
          "when": "editorHasSelection",
          "group": "mimo-agent"
        },
        {
          "command": "mimo-agent.review",
          "when": "editorHasSelection",
          "group": "mimo-agent"
        }
      ],
      "commandPalette": [
        {
          "command": "mimo-agent.chat",
          "when": "*"
        },
        {
          "command": "mimo-agent.clear",
          "when": "*"
        },
        {
          "command": "mimo-agent.settings",
          "when": "*"
        },
        {
          "command": "mimo-agent.explain",
          "when": "editorHasSelection"
        },
        {
          "command": "mimo-agent.review",
          "when": "editorHasSelection"
        },
        {
          "command": "mimo-agent.refactor",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "MiMo",
      "properties": {
        "mimo.apiKey": {
          "type": "string",
          "default": "",
          "description": "MiMo API Key"
        },
        "mimo.baseUrl": {
          "type": "string",
          "default": "https://token-plan-cn.xiaomimimo.com/v1",
          "description": "MiMo API base URL"
        },
        "mimo.model": {
          "type": "string",
          "default": "mimo-v2.5-pro",
          "description": "Model ID"
        },
        "mimo.maxTokens": {
          "type": "number",
          "default": 8192,
          "description": "Max output tokens"
        },
        "mimo.temperature": {
          "type": "number",
          "default": 0.7,
          "description": "Temperature"
        },
        "mimo.enableThinking": {
          "type": "boolean",
          "default": false,
          "description": "Enable MiMo thinking mode"
        },
        "mimo.maxRounds": {
          "type": "number",
          "default": 100,
          "description": "Max tool-calling rounds"
        },
        "mimo.adversarial.maxIterations": {
          "type": "number",
          "default": 3,
          "description": "Max adversarial mode iterations (coder→pm rounds)"
        },
        "mimo.adversarial.toolBudget": {
          "type": "number",
          "default": 10,
          "description": "Tool call budget per persona per iteration"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node build-webview.mjs",
    "watch": "tsc -watch -p ./",
    "build-webview": "node build-webview.mjs",
    "test": "tsc -p ./ && node out/test/index.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "puppeteer-core": "^25.1.0"
  }
}
